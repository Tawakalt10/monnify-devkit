{
  "name": "monnify-devkit",
  "version": "0.1.0",
  "description": "Stripe-CLI-style developer toolkit for the Monnify payment gateway (sandbox only)",
  "type": "module",
  "bin": {
    "monnify": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "monnify",
    "cli",
    "payments",
    "webhooks",
    "nigeria",
    "fintech",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
